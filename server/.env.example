# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Ely.by OAuth
ELY_CLIENT_ID=mc-monitor
ELY_CLIENT_SECRET=your_client_secret_here
ELY_CALLBACK_URL=http://localhost:3000/auth/ely/callback

# Session
SESSION_SECRET=generate_random_secret_here

# Frontend
FRONTEND_URL=http://localhost:8080

# Server
NODE_ENV=development
PORT=3000

# API Configuration
API_TIMEOUT_MS=9000
REALTIME_CHECK_TIMEOUT_MS=1500
RATE_LIMIT_PER_MIN=120

# External APIs
MCSTATUS_API_BASE=https://api.mcstatus.io/v2
ISMCSERVER_API_BASE=https://api.ismcserver.online
ELY_SKIN_BASE=https://skinsystem.ely.by/skins

# Admin
ADMIN_ELY_ID=your_ely_id_for_admin_access
